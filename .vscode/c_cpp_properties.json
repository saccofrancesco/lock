{
  "version": 4,
  "configurations": [
    {
      "name": "macOS-Qt",
      "compilerPath": "/usr/bin/clang++",
      "intelliSenseMode": "macos-clang-arm64",
      "cppStandard": "c++17",
      "compileCommands": "${workspaceFolder}/qt/build/compile_commands.json",
      "includePath": [
        "${workspaceFolder}/qt/include",
        "${workspaceFolder}/qt/src",
        "${workspaceFolder}/**"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/qt/include",
          "${workspaceFolder}/qt/src"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}
